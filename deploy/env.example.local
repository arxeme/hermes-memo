# Connection target for deploy-memo-plugin.sh (env.local is gitignored).
SMC_PROFILE=sea
SERVER_HOST=<test-server-ip>
VM_NAME=<incus-vm-name>
REMOTE_USER=hermes
REMOTE_HERMES_HOME=/home/hermes/.hermes
REMOTE_HERMES_INSTALL_DIR=/home/hermes/.hermes/hermes-agent

# Memo runtime config seeded into HERMES_HOME/memo.json (must be reachable
# from INSIDE the VM — the Incus host gateway, not a tunnel address).
MEMO_BASE_URL=http://<incus-host-gateway>:18000
MEMO_API_KEY=<mate-instance-key>
